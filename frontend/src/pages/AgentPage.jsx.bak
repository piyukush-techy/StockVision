// AgentPage.jsx — Phase 6 Month 27: AI Analyst Agent
// Streaming chat UI with live tool call display
import { useState, useEffect, useRef, useCallback } from 'react';
import { useLocation } from 'react-router-dom';
import { getAgentSuggestions, AGENT_CHAT_URL } from '../api';
import useSessionId from '../hooks/useSessionId';

// ─── Tool metadata (icon + human label) ──────────────────────────────────────
const TOOL_META = {
  get_portfolio_watchlist:  { icon: '⭐', label: 'Fetching your watchlist' },
  get_stock_price:          { icon: '💹', label: 'Getting live price' },
  get_stock_financials:     { icon: '📊', label: 'Loading financials' },
  run_historical_scanner:   { icon: '🔬', label: 'Running historical scan' },
  get_market_regime:        { icon: '🌊', label: 'Analysing market regime' },
  get_stock_news:           { icon: '📰', label: 'Fetching latest news' },
  search_stocks:            { icon: '🔍', label: 'Searching stocks' },
  get_trending_stocks:      { icon: '🔥', label: 'Loading trending stocks' },
  get_user_alerts:          { icon: '🔔', label: 'Checking your alerts' },
};

// ─── Markdown-lite renderer ───────────────────────────────────────────────────
function RenderMarkdown({ text }) {
  const lines = text.split('\n');
  const elements = [];
  let i = 0;

  while (i < lines.length) {
    const line = lines[i];

    // Heading
    if (line.startsWith('### ')) {
      elements.push(<h4 key={i} className="text-white font-bold text-base mt-4 mb-1">{line.slice(4)}</h4>);
    } else if (line.startsWith('## ')) {
      elements.push(<h3 key={i} className="text-white font-bold text-lg mt-4 mb-2">{line.slice(3)}</h3>);
    } else if (line.startsWith('# ')) {
      elements.push(<h2 key={i} className="text-white font-bold text-xl mt-4 mb-2">{line.slice(2)}</h2>);
    }
    // Bold bullet
    else if (line.startsWith('- **') || line.startsWith('* **')) {
      const content = line.slice(2);
      elements.push(
        <div key={i} className="flex items-start gap-2 my-1">
          <span className="text-blue-400 mt-1 flex-shrink-0">•</span>
          <span className="text-gray-200 text-sm leading-relaxed">{renderInline(content)}</span>
        </div>
      );
    }
    // Bullet
    else if (line.startsWith('- ') || line.startsWith('* ')) {
      elements.push(
        <div key={i} className="flex items-start gap-2 my-1">
          <span className="text-blue-400 mt-1 flex-shrink-0">•</span>
          <span className="text-gray-200 text-sm leading-relaxed">{renderInline(line.slice(2))}</span>
        </div>
      );
    }
    // Numbered
    else if (/^\d+\. /.test(line)) {
      const num = line.match(/^(\d+)\. /)[1];
      elements.push(
        <div key={i} className="flex items-start gap-2 my-1">
          <span className="text-blue-400 font-mono text-sm mt-0.5 flex-shrink-0 w-5">{num}.</span>
          <span className="text-gray-200 text-sm leading-relaxed">{renderInline(line.replace(/^\d+\. /, ''))}</span>
        </div>
      );
    }
    // Horizontal rule
    else if (line === '---' || line === '***') {
      elements.push(<hr key={i} className="border-gray-700 my-3" />);
    }
    // Empty line
    else if (line.trim() === '') {
      elements.push(<div key={i} className="h-2" />);
    }
    // Regular paragraph
    else {
      elements.push(
        <p key={i} className="text-gray-200 text-sm leading-relaxed my-1">{renderInline(line)}</p>
      );
    }
    i++;
  }
  return <div className="space-y-0.5">{elements}</div>;
}

function renderInline(text) {
  // Bold + code inline
  const parts = text.split(/(\*\*[^*]+\*\*|`[^`]+`)/g);
  return parts.map((part, i) => {
    if (part.startsWith('**') && part.endsWith('**')) {
      return <strong key={i} className="text-white font-semibold">{part.slice(2, -2)}</strong>;
    }
    if (part.startsWith('`') && part.endsWith('`')) {
      return <code key={i} className="bg-gray-700 text-blue-300 px-1.5 py-0.5 rounded text-xs font-mono">{part.slice(1, -1)}</code>;
    }
    return part;
  });
}

// ─── Tool Call Pill ───────────────────────────────────────────────────────────
function ToolCallPill({ tool, done }) {
  const meta = TOOL_META[tool.toolName] || { icon: '⚙️', label: tool.toolName };
  const inputStr = tool.toolInput
    ? Object.entries(tool.toolInput)
        .filter(([k, v]) => k !== 'sessionId' && v)
        .map(([k, v]) => `${k}: ${v}`)
        .join(', ')
    : '';

  return (
    <div className={`flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-300 ${
      done
        ? 'bg-green-900/40 border border-green-700/40 text-green-300'
        : 'bg-blue-900/40 border border-blue-700/40 text-blue-300'
    }`}>
      <span>{meta.icon}</span>
      <span>{meta.label}{inputStr ? ` — ${inputStr}` : ''}</span>
      {done
        ? <span className="text-green-400">✓</span>
        : <span className="w-3 h-3 border-2 border-blue-400 border-t-transparent rounded-full animate-spin" />
      }
    </div>
  );
}

// ─── Message Bubble ───────────────────────────────────────────────────────────
function MessageBubble({ message }) {
  const isUser = message.role === 'user';

  if (isUser) {
    return (
      <div className="flex justify-end mb-4">
        <div className="max-w-[80%] bg-blue-600 rounded-2xl rounded-br-sm px-4 py-3">
          <p className="text-white text-sm leading-relaxed">{message.content}</p>
        </div>
      </div>
    );
  }

  return (
    <div className="flex items-start gap-3 mb-4">
      {/* Avatar */}
      <div className="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center flex-shrink-0 mt-0.5 shadow-lg">
        <span className="text-white text-xs font-bold">AI</span>
      </div>
      <div className="flex-1 min-w-0">
        {/* Tool calls */}
        {message.toolCalls && message.toolCalls.length > 0 && (
          <div className="flex flex-wrap gap-2 mb-3">
            {message.toolCalls.map((tc, i) => (
              <ToolCallPill key={i} tool={tc} done={tc.done} />
            ))}
          </div>
        )}
        {/* Message text */}
        {message.content && (
          <div className="bg-gray-800/80 border border-gray-700/50 rounded-2xl rounded-tl-sm px-4 py-3">
            <RenderMarkdown text={message.content} />
          </div>
        )}
        {/* Streaming cursor */}
        {message.streaming && (
          <div className="bg-gray-800/80 border border-gray-700/50 rounded-2xl rounded-tl-sm px-4 py-3 mt-1">
            <span className="inline-block w-2 h-4 bg-blue-400 animate-pulse rounded-sm" />
          </div>
        )}
      </div>
    </div>
  );
}

// ─── Suggestion Chip ──────────────────────────────────────────────────────────
function SuggestionChip({ text, onClick }) {
  return (
    <button
      onClick={() => onClick(text)}
      className="text-left px-3 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:border-gray-600 rounded-xl text-sm text-gray-300 hover:text-white transition-all duration-200"
    >
      {text}
    </button>
  );
}

// ─── Main Agent Page ──────────────────────────────────────────────────────────
export default function AgentPage() {
  const sessionId = useSessionId();
  const location  = useLocation();

  const [messages,     setMessages]     = useState([]);
  const [input,        setInput]        = useState('');
  const [loading,      setLoading]      = useState(false);
  const [suggestions,  setSuggestions]  = useState([]);
  const [showHindi,    setShowHindi]    = useState(false);
  const [agentError,   setAgentError]   = useState('');

  const bottomRef  = useRef(null);
  const inputRef   = useRef(null);
  const abortRef   = useRef(null);

  // Detect current context from URL
  const context = {
    page:     location.pathname,
    symbol:   location.pathname.startsWith('/stock/') ? location.pathname.split('/')[2] : null,
    language: showHindi ? 'hindi' : 'english',
  };

  // Load suggestions
  useEffect(() => {
    getAgentSuggestions(context.symbol)
      .then(r => setSuggestions(r.data.suggestions || []))
      .catch(() => {});
  }, [context.symbol]);

  // Auto-scroll
  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  // Welcome message on load
  useEffect(() => {
    setMessages([{
      role: 'assistant',
      content: `Namaste! 🙏 I'm your **StockVision AI Analyst**.

I have live access to your watchlists, real-time NSE prices, the historical scanner, regime analysis, news, and more. Ask me anything about Indian stocks.

**Try asking:**
- "Show me my watchlist with current prices"
- "Run the scanner on RELIANCE.NS — can it hit 20% in 90 days?"
- "What's the current market regime for NIFTY?"
- "मुझे TCS के बारे में बताओ" (Hindi also works!)

*I'm not SEBI registered. This is not financial advice.*`,
      toolCalls: [],
    }]);
  }, []);

  const sendMessage = useCallback(async (text) => {
    const userText = (text || input).trim();
    if (!userText || loading) return;

    setInput('');
    setAgentError('');
    setLoading(true);

    // Add user message
    const userMsg = { role: 'user', content: userText };
    const newMessages = [...messages, userMsg];
    setMessages(newMessages);

    // Placeholder assistant message
    const assistantId = Date.now();
    setMessages(prev => [...prev, {
      id:        assistantId,
      role:      'assistant',
      content:   '',
      toolCalls: [],
      streaming: true,
    }]);

    try {
      // Build history for API (exclude the streaming placeholder and welcome msg)
      const historyMsgs = newMessages
        .slice(-10) // last 10 for context window
        .map(m => ({ role: m.role, content: m.content }));

      // Abort previous request if any
      if (abortRef.current) abortRef.current.abort();
      abortRef.current = new AbortController();

      const response = await fetch(AGENT_CHAT_URL, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        signal:  abortRef.current.signal,
        body:    JSON.stringify({ messages: historyMsgs, sessionId, context }),
      });

      if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Request failed' }));
        throw new Error(err.error || `HTTP ${response.status}`);
      }

      const reader  = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer    = '';
      let fullText  = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop(); // keep incomplete line

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          let event;
          try { event = JSON.parse(line.slice(6)); } catch { continue; }

          if (event.type === 'text_delta') {
            fullText += event.delta;
            setMessages(prev => prev.map(m =>
              m.id === assistantId ? { ...m, content: fullText, streaming: true } : m
            ));
          }

          else if (event.type === 'tool_start') {
            setMessages(prev => prev.map(m =>
              m.id === assistantId
                ? { ...m, streaming: true, toolCalls: [...(m.toolCalls || []), { ...event, done: false }] }
                : m
            ));
          }

          else if (event.type === 'tool_end') {
            setMessages(prev => prev.map(m =>
              m.id === assistantId
                ? { ...m, toolCalls: (m.toolCalls || []).map(tc =>
                    tc.toolId === event.toolId ? { ...tc, done: true, result: event.result } : tc
                  )}
                : m
            ));
          }

          else if (event.type === 'done') {
            setMessages(prev => prev.map(m =>
              m.id === assistantId ? { ...m, streaming: false } : m
            ));
          }

          else if (event.type === 'error') {
            setAgentError(event.message || 'Agent error');
            setMessages(prev => prev.map(m =>
              m.id === assistantId
                ? { ...m, content: `❌ ${event.message || 'Something went wrong. Please try again.'}`, streaming: false }
                : m
            ));
          }
        }
      }

      // Final cleanup — remove streaming flag
      setMessages(prev => prev.map(m =>
        m.id === assistantId ? { ...m, streaming: false } : m
      ));

    } catch (err) {
      if (err.name === 'AbortError') return;

      const errMsg = err.message.includes('ANTHROPIC_API_KEY')
        ? '⚠️ AI Agent not configured. Add your ANTHROPIC_API_KEY to the backend .env file. Get a free key at console.anthropic.com'
        : `❌ ${err.message || 'Something went wrong. Please try again.'}`;

      setMessages(prev => prev.map(m =>
        m.id === assistantId ? { ...m, content: errMsg, streaming: false } : m
      ));
    } finally {
      setLoading(false);
      setTimeout(() => inputRef.current?.focus(), 100);
    }
  }, [input, messages, loading, sessionId, context]);

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  const isEmpty = messages.length <= 1;

  return (
    <div className="flex flex-col h-[calc(100vh-120px)] max-w-4xl mx-auto px-4">

      {/* Header */}
      <div className="flex items-center justify-between py-4 border-b border-gray-800 mb-4 flex-shrink-0">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg">
            <span className="text-white font-bold text-sm">AI</span>
          </div>
          <div>
            <h1 className="text-white font-bold text-lg leading-none">StockVision AI Analyst</h1>
            <p className="text-gray-500 text-xs mt-0.5">Powered by Claude · Live NSE/BSE data</p>
          </div>
          <div className="flex items-center gap-1.5 px-2 py-1 bg-green-900/30 border border-green-700/40 rounded-full">
            <span className="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse" />
            <span className="text-green-400 text-xs font-medium">Live</span>
          </div>
        </div>
        <div className="flex items-center gap-3">
          {/* Hindi toggle */}
          <button
            onClick={() => setShowHindi(h => !h)}
            className={`flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
              showHindi
                ? 'bg-orange-900/40 border border-orange-700/40 text-orange-300'
                : 'bg-gray-800 border border-gray-700 text-gray-400 hover:text-white'
            }`}
          >
            🇮🇳 हिंदी {showHindi ? 'On' : 'Off'}
          </button>
          {/* Clear chat */}
          <button
            onClick={() => {
              setMessages([]);
              setAgentError('');
              setTimeout(() => setMessages([{
                role: 'assistant',
                content: 'Chat cleared! Ask me anything about Indian stocks.',
                toolCalls: [],
              }]), 50);
            }}
            className="text-gray-500 hover:text-gray-300 text-sm px-2 py-1 rounded transition-colors"
          >
            Clear
          </button>
        </div>
      </div>

      {/* Messages */}
      <div className="flex-1 overflow-y-auto pr-1 space-y-1 scrollbar-thin scrollbar-thumb-gray-700">
        {messages.map((msg, i) => (
          <MessageBubble key={msg.id || i} message={msg} />
        ))}

        {/* Suggestions — show when only welcome message */}
        {isEmpty && suggestions.length > 0 && (
          <div className="ml-11 mt-2">
            <p className="text-gray-500 text-xs mb-2 font-medium">Suggested questions</p>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {suggestions.slice(0, 6).map((s, i) => (
                <SuggestionChip key={i} text={s} onClick={sendMessage} />
              ))}
            </div>
          </div>
        )}

        <div ref={bottomRef} />
      </div>

      {/* Error banner */}
      {agentError && agentError.includes('ANTHROPIC_API_KEY') && (
        <div className="flex-shrink-0 bg-amber-900/20 border border-amber-700/40 rounded-xl p-3 mb-3 text-sm text-amber-300">
          ⚠️ <strong>Setup needed:</strong> Add <code className="bg-amber-900/40 px-1 rounded">ANTHROPIC_API_KEY=sk-ant-...</code> to your <code className="bg-amber-900/40 px-1 rounded">backend/.env</code> file.
          Get a free key at <a href="https://console.anthropic.com" target="_blank" rel="noreferrer" className="underline">console.anthropic.com</a>
        </div>
      )}

      {/* Input area */}
      <div className="flex-shrink-0 pt-3 pb-2 border-t border-gray-800">
        <div className="flex items-end gap-3">
          <div className="flex-1 relative">
            <textarea
              ref={inputRef}
              value={input}
              onChange={e => setInput(e.target.value)}
              onKeyDown={handleKey}
              disabled={loading}
              rows={1}
              placeholder={showHindi ? 'कोई भी सवाल पूछें... (Enter to send)' : 'Ask anything about Indian stocks... (Enter to send)'}
              className="w-full bg-gray-800 border border-gray-700 focus:border-blue-500 rounded-2xl px-4 py-3 text-white placeholder-gray-500 text-sm resize-none focus:outline-none transition-colors disabled:opacity-50"
              style={{ minHeight: '48px', maxHeight: '120px' }}
              onInput={e => {
                e.target.style.height = 'auto';
                e.target.style.height = Math.min(e.target.scrollHeight, 120) + 'px';
              }}
            />
          </div>
          <button
            onClick={() => sendMessage()}
            disabled={loading || !input.trim()}
            className="w-12 h-12 bg-blue-600 hover:bg-blue-500 disabled:bg-gray-700 disabled:cursor-not-allowed rounded-2xl flex items-center justify-center transition-all duration-200 flex-shrink-0 shadow-lg hover:shadow-blue-500/25"
          >
            {loading
              ? <span className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
              : <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
            }
          </button>
        </div>
        <p className="text-gray-600 text-xs text-center mt-2">
          Not SEBI registered · Not financial advice · Powered by Claude AI
        </p>
      </div>
    </div>
  );
}
